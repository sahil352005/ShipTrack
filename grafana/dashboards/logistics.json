{
  "id": null,
  "uid": "logistics-main",
  "title": "Logistics & Supply Chain Analytics",
  "tags": ["logistics", "realtime"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Shipments",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value FROM shipments",
        "format": "table",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "Total Delayed",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value FROM shipments WHERE is_delayed = TRUE",
        "format": "table",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }] } } }
    },
    {
      "id": 3,
      "title": "On-Time Rate %",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN NOT is_delayed THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 2) AS value FROM shipments",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "green", "value": 90 }] } } }
    },
    {
      "id": 4,
      "title": "Avg Delivery Hours",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT ROUND(AVG(actual_delivery_hours)::numeric, 2) AS value FROM shipments WHERE actual_delivery_hours IS NOT NULL",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "h", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 12 }, { "color": "red", "value": 24 }] } } }
    },
    {
      "id": 5,
      "title": "Shipments by Status",
      "type": "piechart",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT status AS metric, COUNT(*) AS value FROM shipments GROUP BY status",
        "format": "table",
        "refId": "A"
      }],
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] }
    },
    {
      "id": 6,
      "title": "Shipments Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT date_trunc('minute', event_timestamp) AS time, COUNT(*) AS shipments FROM shipments WHERE $__timeFilter(event_timestamp) GROUP BY 1 ORDER BY 1",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 7,
      "title": "On-Time vs Delayed by Region",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT region, SUM(CASE WHEN NOT is_delayed THEN 1 ELSE 0 END) AS on_time, SUM(CASE WHEN is_delayed THEN 1 ELSE 0 END) AS delayed FROM shipments GROUP BY region ORDER BY region",
        "format": "table",
        "refId": "A"
      }],
      "options": { "xField": "region" }
    },
    {
      "id": 8,
      "title": "Route Performance — On-Time Rate by Region",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT DISTINCT ON (region) region AS metric, on_time_rate AS value FROM route_performance ORDER BY region, window_start DESC",
        "format": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "green", "value": 90 }] } } },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 9,
      "title": "Warehouse Analytics",
      "type": "table",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT warehouse_id, COUNT(*) AS total_shipments, SUM(CASE WHEN is_delayed THEN 1 ELSE 0 END) AS delayed, ROUND(AVG(distance_km)::numeric,2) AS avg_distance_km, ROUND(100.0 * SUM(CASE WHEN NOT is_delayed THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0),2) AS on_time_pct FROM shipments GROUP BY warehouse_id ORDER BY total_shipments DESC",
        "format": "table",
        "refId": "A"
      }],
      "options": { "sortBy": [{ "displayName": "total_shipments", "desc": true }] }
    },
    {
      "id": 10,
      "title": "Delivery Time Trend (Avg Hours)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": "PostgreSQL",
      "targets": [{
        "rawSql": "SELECT date_trunc('minute', event_timestamp) AS time, ROUND(AVG(actual_delivery_hours)::numeric, 2) AS avg_delivery_hours FROM shipments WHERE actual_delivery_hours IS NOT NULL AND $__timeFilter(event_timestamp) GROUP BY 1 ORDER BY 1",
        "format": "time_series",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "h", "color": { "mode": "palette-classic" } } }
    }
  ]
}
